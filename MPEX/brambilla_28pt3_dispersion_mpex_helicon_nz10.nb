   "nprof", ",", " ", "bprof", ",", " ", "tprof", ",", " ", "nprof2", ",", 
    " ", "bprof2", ",", " ", "tprof2", ",", " ", "mpexEta"}], "]"}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"mpexEta", "[", 
    RowBox[{"x_", "?", "NumericQ"}], "]"}], " ", ":=", " ", 
   RowBox[{"Clip", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"(", 
       RowBox[{"x", " ", "-", " ", "xProfileMin"}], ")"}], "/", 
      RowBox[{"(", 
       RowBox[{"xProfileMax", " ", "-", " ", "xProfileMin"}], ")"}]}], ",", 
     " ", 
     RowBox[{"{", 
      RowBox[{"0", ",", " ", "1"}], "}"}]}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"bprof2", "[", 
    RowBox[{"x_", "?", "NumericQ"}], "]"}], " ", ":=", " ", "BXmin"}], 
  ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"nprof2", "[", 
    RowBox[{"x_", "?", "NumericQ"}], "]"}], " ", ":=", " ", 
   RowBox[{"nXmin", "*", 
    RowBox[{"Exp", "[", 
     RowBox[{
      RowBox[{"Log", "[", 
       RowBox[{"nXmax", "/", "nXmin"}], "]"}], "*", 
      RowBox[{
       RowBox[{"mpexEta", "[", "x", "]"}], "^", "2"}]}], "]"}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"tprof2", "[", 
    RowBox[{"x_", "?", "NumericQ"}], "]"}], " ", ":=", " ", 
   RowBox[{"TXmin", " ", "+", " ", 
    RowBox[{
     RowBox[{"mpexEta", "[", "x", "]"}], "*", 
     RowBox[{"(", 
      RowBox[{"TXmax", " ", "-", " ", "TXmin"}], ")"}]}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"bprof", "[", 
    RowBox[{"x_", "?", "NumericQ"}], "]"}], " ", ":=", " ", 
   RowBox[{"bprof2", "[", "x", "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"nprof", "[", 
    RowBox[{"x_", "?", "NumericQ"}], "]"}], " ", ":=", " ", 
   RowBox[{"nprof2", "[", "x", "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"tprof", "[", 
    RowBox[{"x_", "?", "NumericQ"}], "]"}], " ", ":=", " ", 
   RowBox[{"tprof2", "[", "x", "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"wci", " ", "=", " ", 
   RowBox[{"q", "*", 
    RowBox[{
     RowBox[{"bprof", "[", "x", "]"}], "/", "mi"}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"wce", " ", "=", " ", 
   RowBox[{"q", "*", 
    RowBox[{
     RowBox[{"bprof", "[", "x", "]"}], "/", "me"}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"wpe", " ", "=", " ", 
   RowBox[{"Sqrt", "[", 
    RowBox[{
     RowBox[{"nprof", "[", "x", "]"}], "*", 
     RowBox[{
      RowBox[{"q", "^", "2"}], "/", 
      RowBox[{"(", 
       RowBox[{"ep0", "*", "me"}], ")"}]}]}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"dh", " ", "=", " ", 
   RowBox[{"Plot", "[", 
    RowBox[{
     RowBox[{"5", "/", 
      RowBox[{"Mod", "[", 
