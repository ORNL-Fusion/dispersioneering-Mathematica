Cell["Now Try with Hot Plasma Dispersion using root finder", "Section",
 CellChangeTimes->{{3.7856310546593847`*^9, 3.78563110052183*^9}, {
  3.785755944014817*^9, 
  3.785755948051633*^9}},ExpressionUUID->"82b513d6-585b-4d59-bc44-\
5afe3bd214d6"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"ClearAll", "[", "nPerpHot", "]"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"nPerpHot", "[", 
   RowBox[{
    RowBox[{"x_", "?", "NumericQ"}], ",", " ", "nxGuess_"}], "]"}], " ", ":=",
   " ", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "ne", ",", " ", "b", ",", " ", "x0", ",", " ", "TL", ",", " ", "nx0", ",",
       " ", "rootRule", ",", " ", "rootValue"}], "}"}], ",", "\n", "  ", 
    RowBox[{
     RowBox[{"x0", " ", "=", " ", "x"}], ";", "\n", "  ", 
     RowBox[{"nx0", " ", "=", " ", "nxGuess"}], ";", "\n", "  ", 
     RowBox[{"ne", " ", "=", " ", 
