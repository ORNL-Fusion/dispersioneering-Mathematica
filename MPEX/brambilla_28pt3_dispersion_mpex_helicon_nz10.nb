Cell["Focus on the damping", "Section",
 CellChangeTimes->{{3.788313386898919*^9, 
  3.7883134000871353`*^9}},ExpressionUUID->"2ed9bcd4-877c-4f87-afbf-\
60079e96b5b5"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"nxhotIm", "[", "iRoot_", "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "iRoot0", ",", "nxWarm", ",", "rootsWarm", ",", "nxH", ",", "x0", ",", 
       "ne", ",", "b", ",", "t", ",", "TL"}], "}"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"nxWarm", "=", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"Flatten", "[", 
          RowBox[{"{", 
           RowBox[{"x", ",", 
            RowBox[{"nPerpWarm6", "[", "x", "]"}]}], "}"}], "]"}], ",", 
         RowBox[{"{", 
          RowBox[{"x", ",", "xmin", ",", "xmax", ",", 
           FractionBox[
            RowBox[{"xmax", "-", "xmin"}], 
            RowBox[{"nPoints", "-", "1"}]]}], "}"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"iRoot0", "=", "iRoot"}], ";", "\[IndentingNewLine]", 
      RowBox[{"rootsWarm", "=", 
       RowBox[{"rootSort", "[", "nxWarm", "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"nxH", "=", 
       RowBox[{"Table", "[", 
        RowBox[{"0.", ",", 
         RowBox[{"{", 
          RowBox[{"i", ",", "1", ",", "nPoints"}], "}"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"Do", "[", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          RowBox[{"x0", "=", 
           RowBox[{"xmin", "+", 
            RowBox[{
             RowBox[{"(", 
              RowBox[{"i", "-", "1"}], ")"}], 
             FractionBox[
              RowBox[{"xmax", "-", "xmin"}], 
              RowBox[{"nPoints", "-", "1"}]]}]}]}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"nxGuess", "=", 
           RowBox[{
            RowBox[{"rootsWarm", "[", 
             RowBox[{"[", "i", "]"}], "]"}], "[", 
            RowBox[{"[", 
             RowBox[{"iRoot0", "+", "1"}], "]"}], "]"}]}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"(*", 
           RowBox[{
            RowBox[{"Print", "[", 
             
             RowBox[{"\"\<x0 = \>\"", ",", " ", "x0", 
              ",", "\"\<  nxGuess= \>\"", ",", "nxGuess"}], "]"}], ";"}], 
           "*)"}], "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"nxH", "[", 
            RowBox[{"[", "i", "]"}], "]"}], "=", 
           RowBox[{"{", 
            RowBox[{"x0", ",", 
             RowBox[{"Im", "[", 
              RowBox[{"nPerpHot", "[", 
               RowBox[{"x0", ",", "nxGuess"}], "]"}], "]"}]}], "}"}]}], ";"}],
          ")"}], ",", 
        RowBox[{"{", 
         RowBox[{"i", ",", "1", ",", "nPoints"}], "}"}]}], "]"}], ";", 
      "\[IndentingNewLine]", "nxH"}]}], "]"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.7883010530893297`*^9, 3.788301075483989*^9}},
 CellLabel->
  "In[669]:=",ExpressionUUID->"e678bbc5-9363-44b3-a167-72dabc10443a"],

