Cell["\<\
Plot Real and Imaginary parts of nx from 4nd order
cold plasma dispersion relation (i.e. fast and slow)\
\>", "Section",
 CellChangeTimes->{{3.785615464255439*^9, 3.785615553094365*^9}, 
   3.78561563227316*^9, {3.785615908934442*^9, 3.785615952863583*^9}, {
   3.828616839694118*^9, 3.828616840918948*^9}},
 AspectRatioFixed->
  True,ExpressionUUID->"1434a51a-6632-47a8-9f6f-59610c7c8da0"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"nPerp2FS", "[", "x_", "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"ne", ",", "b", ",", "x0"}], "}"}], ",", 
    RowBox[{
     RowBox[{"x0", "=", "x"}], ";", "\[IndentingNewLine]", 
     RowBox[{"ne", "=", 
      RowBox[{"nprof", "[", "x0", "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"b", "=", 
      RowBox[{"bprof", "[", "x0", "]"}]}], ";", "\n", "\t\t", 
     RowBox[{"ColdDis2FS", "[", 
      RowBox[{"freq", ",", "ne", ",", "b", ",", "nz", ",", "etaList"}], 
      "]"}]}]}], "]"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"nt2FS", "=", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"Flatten", "[", 
      RowBox[{"{", 
       RowBox[{"x", ",", 
        RowBox[{"nPerp2FS", "[", "x", "]"}]}], "}"}], "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", "xmin", ",", "xmax", ",", 
       FractionBox[
        RowBox[{"xmax", "-", "xmin"}], 
        RowBox[{"nPoints", "-", "1"}]]}], "}"}]}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"nF", "=", 
   RowBox[{"Transpose", "[", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       RowBox[{"Transpose", "[", "nt2FS", "]"}], "\[LeftDoubleBracket]", "1", 
       "\[RightDoubleBracket]"}], ",", 
      RowBox[{
       RowBox[{"Transpose", "[", "nt2FS", "]"}], "\[LeftDoubleBracket]", "2", 
