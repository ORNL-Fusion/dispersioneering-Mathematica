Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"nPerpWarm6", "[", "x_", "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"ne", ",", "te", ",", "b", ",", "x0", ",", "TL"}], "}"}], ",", 
     RowBox[{
      RowBox[{"x0", "=", "x"}], ";", 
      RowBox[{"ne", "=", 
       RowBox[{"nprof", "[", "x0", "]"}]}], ";", 
      RowBox[{"b", "=", 
       RowBox[{"bprof", "[", "x0", "]"}]}], ";", 
      RowBox[{"TL", "=", 
       RowBox[{
        RowBox[{"tprof", "[", "x0", "]"}], " ", "*", "TList"}]}], ";", " ", 
      RowBox[{"WarmDis6", "[", 
       RowBox[{
       "freq", ",", "ne", ",", "b", ",", "nz", ",", "etaList", ",", "TL"}], 
       "]"}]}]}], "]"}]}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"nxwarm", "=", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"Flatten", "[", 
      RowBox[{"{", 
       RowBox[{"x", ",", 
        RowBox[{"nPerpWarm6", "[", "x", "]"}]}], "}"}], "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", "xmin", ",", "xmax", ",", 
       FractionBox[
        RowBox[{"xmax", "-", "xmin"}], 
        RowBox[{"nPoints", "-", "1"}]]}], "}"}]}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"roots", "=", 
   RowBox[{"rootSort", "[", "nxwarm", "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"rootsRe", "=", 
