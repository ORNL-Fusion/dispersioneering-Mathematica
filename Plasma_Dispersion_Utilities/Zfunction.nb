Cell[CellGroupData[{

Cell["\<\
They agree very well.  What happens if we use the choice of s in the \
asymptotic expansion given in the NRL formulary?\
\>", "Subsection",
 Evaluatable->False,
 CellChangeTimes->{{3.788017430472093*^9, 3.788017431234089*^9}, 
   3.876351546738447*^9, {3.8763921328367033`*^9, 3.876392147192421*^9}, 
   3.876392199454721*^9},
 AspectRatioFixed->
  True,ExpressionUUID->"c4156a87-ca08-4e1f-a829-d01dec2df9a4"],

Cell["\<\
ZAsymp2[z_Complex]:=Module[{s,a,y,q,z2},
\t\t\ta=Abs[Re[z]];
\t\t\ty=Im[z];
\t\t\tWhich[y>1/a,s=0,  Abs[y]<1/a,s=1,   y<-1/a,s=2];
\t\t\tz2=z^2;
\t\t\tq=(1+1/(2 z2)+3/(4 z2^2)+15/(8 z2^3)+7*15/(16 z2^4))/z;
\t\t\tN[1.772453851*I*s*E^(-z2)-q]
\t\t\t]\
\>", "Input",
 CellChangeTimes->{{3.876351611495707*^9, 3.876351615862935*^9}, {
   3.8763516459230328`*^9, 3.876351668455744*^9}, 3.876353136494426*^9},
 AspectRatioFixed->True,
 CellLabel->
  "In[238]:=",ExpressionUUID->"6e2db1ee-58e2-4815-b3a9-1f7966f90d0e"]
}, Open  ]],

Cell[CellGroupData[{

Cell["\<\
r=3.;
Plot[{Re[ZAsymp[r*Exp[\[ImaginaryI] theta]]],Im[ZAsymp[r*Exp[\[ImaginaryI] \
theta]]]},{theta,0.,2 \[Pi]},PlotRange\[Rule]All]
Plot[{Re[ZAsymp2[r*Exp[\[ImaginaryI] theta]]],Im[ZAsymp2[r*Exp[\[ImaginaryI] \
theta]]]},{theta,0.,2 \[Pi]},PlotRange\[Rule]All]
Plot[{Re[ZAsymp[r*Exp[\[ImaginaryI] theta]]-ZAsymp2[r*Exp[\[ImaginaryI] \
theta]]],Im[ZAsymp[r*Exp[\[ImaginaryI] theta]]-ZAsymp2[r*Exp[\[ImaginaryI] \
theta]]]},{theta,0.,2 \[Pi]},PlotRange\[Rule]All]


\
\>", "Input",
