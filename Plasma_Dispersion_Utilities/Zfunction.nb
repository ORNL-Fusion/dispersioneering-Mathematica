Cell["\<\
Which raises the question : Does the Erf form have the wiggles at about 1.5 \
or not?\
\>", "Subsection",
 CellChangeTimes->{{3.876354043447196*^9, 
  3.8763541227183447`*^9}},ExpressionUUID->"cb99fd1f-8f85-4835-b833-\
ee282c7de53c"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"r", "=", "5."}], ";"}], "\[IndentingNewLine]", 
   RowBox[{"Plot", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"Re", "[", 
        RowBox[{"Zf", "[", 
         RowBox[{"r", "*", 
          RowBox[{"Exp", "[", 
           RowBox[{"\[ImaginaryI]", " ", "theta"}], "]"}]}], "]"}], "]"}], 
       ",", 
       RowBox[{"Im", "[", 
        RowBox[{"Zf", "[", 
         RowBox[{"r", "*", 
          RowBox[{"Exp", "[", 
           RowBox[{"\[ImaginaryI]", " ", "theta"}], "]"}]}], "]"}], "]"}]}], 
      "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"theta", ",", "0.", ",", 
       RowBox[{"2", " ", "\[Pi]"}]}], "}"}], ",", 
     RowBox[{"PlotRange", "\[Rule]", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"-", ".0005"}], ",", " ", ".0005"}], "}"}]}]}], 
    "]"}]}]}]], "Input",
