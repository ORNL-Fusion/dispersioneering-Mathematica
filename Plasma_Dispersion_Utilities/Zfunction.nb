Cell["Set transition to asymptotics small, M=1.5 and look at break", "Section",
 CellChangeTimes->{{3.788017451079021*^9, 3.7880174979297953`*^9}, {
  3.788017533077532*^9, 3.788017534362091*^9}, {3.8763532911028757`*^9, 
  3.8763533195866947`*^9}, {3.876353361214014*^9, 3.876353383482774*^9}, {
  3.876353597257621*^9, 
  3.876353597933309*^9}},ExpressionUUID->"43da510a-1c56-467f-961d-\
6ffb48ab1987"],

Cell["\<\
Zfun[z0_]:=Module[{M=1.5,s,y,q,z2},
z=N[z0];
If[Abs[z]<M,

1.772453851*I* E^(-z^2)(1+ Erf[I z]),\t(* error function form  *)
\t
\ty=Im[z];\t(* asymptotic expansion *)
\tWhich[y==0.,s=1,  y>0,s=0,   y<0,s=2];
\tz2=z^2;
\tq=(1+1/(2 z2)+3/(4 z2^2)+15/(8 z2^3)+7*15/(16 z2^4))/z;
\t1.772453851*I*s*E^(-z2)-q\t\t(* end of asymptotic expansion *)
]\t(* end if  *)
]\t(* end module *)\
\>", "Input",
 CellChangeTimes->{
  3.876346375651346*^9, 3.876350203989169*^9, 3.876350244933475*^9, {
   3.876350294170067*^9, 3.8763503203478127`*^9}, 3.876352658550068*^9, 
   3.876353389935014*^9, {3.876353431612022*^9, 3.8763534504879923`*^9}},
 AspectRatioFixed->True,
 CellLabel->
  "In[253]:=",ExpressionUUID->"390fa5c6-4042-423b-9f99-212b0b16f91d"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"zf", "=", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"z", ",", 
       RowBox[{"Zfun", "[", "z", "]"}]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"z", ",", 
       RowBox[{"-", "4"}], ",", "4", ",", ".001"}], "}"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{"ComplexVectorListPlot", "[", 
  RowBox[{"zf", ",", "\"\<z\>\"", ",", "\"\<Zfun[z]\>\"", ",", " ", 
   RowBox[{"PlotRange", "\[Rule]", "All"}]}], 
  "]"}], "\[IndentingNewLine]"}], "Input",
 CellChangeTimes->{{3.788008968866963*^9, 3.7880090866421213`*^9}, {
  3.788009137204782*^9, 3.788009163950309*^9}, {3.788009210721932*^9, 
