(* Beginning of Notebook Content *)
Notebook[{
Cell["Numerical implementation of the Z function", "Title",
 CellMargins->{{Inherited, 107}, {Inherited, Inherited}},
 Evaluatable->False,
 AspectRatioFixed->
  True,ExpressionUUID->"789af009-816c-409e-bd9e-36a7e699c5f8"],

Cell["\<\
This implementation uses the representation in terms of error functions for \
small argument |z|<M and asymptotic expansion for argument |z| > M. Now M=4. 
Note: The choice of s in the asymptotic expansion is different from that \
given in the plasma formulary (their sigma).  Use of their sigma clearly \
doesn't work for example when Re[z] =0.  Then sigma must be 0 whereas their \
forumlua would have sigma=1.\
\>", "Text",
 Evaluatable->False,
 CellChangeTimes->{{3.876353730008833*^9, 3.8763537558748817`*^9}},
 AspectRatioFixed->
  True,ExpressionUUID->"974340cb-6498-447c-b41c-3ac11101800f"],

Cell["Z function module", "Subsection",
 Evaluatable->False,
 AspectRatioFixed->
  True,ExpressionUUID->"109054fd-06b3-4f00-939e-ce7505ad6dea"],

Cell["\<\
Zfun[z0_]:=Module[{M=4.,s,y,q,z2},
z=N[z0];
If[Abs[z]<M,

1.772453851*I* E^(-z^2)(1+ Erf[I z]),\t(* error function form  *)
\t
\ty=Im[z];\t(* asymptotic expansion *)
\tWhich[y==0.,s=1,  y>0,s=0,   y<0,s=2];
\tz2=z^2;
\tq=(1+1/(2 z2)+3/(4 z2^2)+15/(8 z2^3)+7*15/(16 z2^4))/z;
\t1.772453851*I*s*E^(-z2)-q\t\t(* end of asymptotic expansion *)
]\t(* end if  *)
]\t(* end module *)\
\>", "Input",
 CellChangeTimes->{
  3.876346375651346*^9, 3.876350203989169*^9, 3.876350244933475*^9, {
   3.876350294170067*^9, 3.8763503203478127`*^9}, 3.876352658550068*^9},
 AspectRatioFixed->True,
 CellLabel->
  "In[268]:=",ExpressionUUID->"08337223-432e-4852-ac0c-3e447ef28d0a"],

Cell["Testing of Zfun", "Section",
 Evaluatable->False,
 AspectRatioFixed->
  True,ExpressionUUID->"77ff01f3-53aa-4aaa-81c2-732d400208ba"],

