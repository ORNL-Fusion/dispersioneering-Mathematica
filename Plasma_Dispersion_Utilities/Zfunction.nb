Cell["Asymptotic expansion", "Subsection",
 CellChangeTimes->{{3.876346563991131*^9, 
  3.876346580815652*^9}},ExpressionUUID->"939d4187-01a3-483e-936e-\
f6429fcff491"],

Cell["\<\
ZAsymp[z_]:=Module[{s,a,y,q,z2},
\t\t\ta=Abs[Re[z]];
\t\t\ty=Im[z];
\t\t\tWhich[y==0.,s=1,  y>0,s=0,   y<0,s=2];
\t\t\tz2=z^2;
\t\t\tq=(1+1/(2 z2)+3/(4 z2^2)+15/(8 z2^3)+7*15/(16 z2^4))/z;
\t\t\tN[1.772453851*I*s*E^(-z2)-q]
\t\t\t]\
\>", "Input",
 AspectRatioFixed->True,
 CellLabel->
  "In[208]:=",ExpressionUUID->"a4260767-453a-4419-b798-7f2b168f789b"],

