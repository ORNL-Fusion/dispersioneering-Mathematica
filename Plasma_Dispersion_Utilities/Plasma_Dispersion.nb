Cell[CellGroupData[{

Cell[TextData[{
 "Expansion coefficients for Hermitian part of warm plasma conductivity \
tensor, 4\[Pi]i/\[Omega] \[Sigma], for a single isotropic Maxwellian species, \
expanded to 2nd order in k",
 StyleBox["\[UpTee]",
  FontVariations->{"CompatibilityType"->"Subscript"}],
 "\[Rho]. \nN.B. The conductivity here is actually 4\[Pi]i/\[Omega] \[Sigma]. \
 So ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    RowBox[{"(", 
     RowBox[{"4", 
      RowBox[{"\[Pi]i", "/", "\[Omega]"}], " ", "\[Sigma]"}], ")"}], "H"], 
   TraditionalForm]],ExpressionUUID->"a5726916-496a-45f7-8312-768c435fabe7"],
 " is  effectively the non-dissipative part.  See note at top.\n"
}], "Subsection",
