 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Sigma]", "12"], TraditionalForm]],ExpressionUUID->
  "99dcb959-38a6-4d2f-893d-5769b86f0538"],
 "}, also notated as in Stix {S, S, P, -\[ImaginaryI]D}"
}], "Subsection",
 CellChangeTimes->{{3.974991712577771*^9, 3.974991719619083*^9}, {
  3.976462529117564*^9, 3.976462722838243*^9}},
