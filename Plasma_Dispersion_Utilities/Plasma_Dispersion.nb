Cell[TextData[{
 "N . B .  Stix (Eq 1-29) defines b as negative of the usual quadratic \
eqation b.  i.e. A",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SuperscriptBox["n", "4"], "-", " ", 
     SuperscriptBox["Bn", 
      RowBox[{"2", " "}]], "+", "C"}], " ", "=", 
    RowBox[{"0.", "  ", "This", " "}]}], TraditionalForm]],ExpressionUUID->
  "e6307120-a32a-47fd-a74e-692229267201"],
 "has the effect of making O-mode correspond to + discr below, and X-mode \
correspond to - discr."
}], "Text",
 CellChangeTimes->{{3.980859998821252*^9, 3.980860249313459*^9}, {
  3.9808602921365833`*^9, 
  3.980860347425387*^9}},ExpressionUUID->"7fac0985-34c0-4ba4-9597-\
30f5d82784a0"],

