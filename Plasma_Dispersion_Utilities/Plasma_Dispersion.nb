     RowBox[{
      RowBox[{"mass", "[", "4", "]"}], "=", "5496."}], ";", 
     RowBox[{
      RowBox[{"mass", "[", "5", "]"}], "=", "7294."}], ";", 
     RowBox[{
      RowBox[{"chg", "[", "0", "]"}], "=", 
      RowBox[{"-", "1."}]}], ";", 
     RowBox[{
      RowBox[{"chg", "[", "1", "]"}], "=", "1."}], ";", 
     RowBox[{
      RowBox[{"chg", "[", "2", "]"}], "=", "1."}], ";", 
     RowBox[{
      RowBox[{"chg", "[", "3", "]"}], "=", "1."}], ";", 
     RowBox[{
      RowBox[{"chg", "[", "4", "]"}], "=", "2."}], ";", 
     RowBox[{
      RowBox[{"chg", "[", "5", "]"}], "=", "2."}], ";", 
     RowBox[{"Do", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"fp", "[", "i", "]"}], "=", 
        FractionBox[
         RowBox[{"8.9787", " ", 
          SqrtBox[
           FractionBox[
            RowBox[{"n0", " ", 
             RowBox[{"eta", "[", "i", "]"}], " ", 
             SuperscriptBox[
              RowBox[{"chg", "[", "i", "]"}], "2"]}], 
            RowBox[{"mass", "[", "i", "]"}]]]}], 
