     RowBox[{"Do", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"fc", "[", "i", "]"}], "=", 
        FractionBox[
         RowBox[{"2.79926", " ", "B0", " ", 
          RowBox[{"chg", "[", "i", "]"}]}], 
         RowBox[{"mass", "[", "i", "]"}]]}], ",", 
       RowBox[{"{", 
        RowBox[{"i", ",", "0", ",", "5"}], "}"}]}], "]"}], ";", 
     RowBox[{"R", "=", 
      RowBox[{"1", "-", 
       RowBox[{
        UnderoverscriptBox["\[Sum]", 
