Cell[TextData[{
 "nxColdDisNyNzPM[freq, ne, B,ny, nz, etaList] \[Dash] 4th Order cold plasma \
dispersion solver. Returns ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["n", "x"], TraditionalForm]],ExpressionUUID->
