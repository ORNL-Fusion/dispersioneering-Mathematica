Cell[BoxData[
 RowBox[{
  RowBox[{"PlasmaFreqHzMKS", "[", 
   RowBox[{"i_", ",", "ne_", ",", "eta_", ",", 
    RowBox[{"print_", ":", "False"}]}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"n0", ",", "mass", ",", "chg", ",", "fp"}], "}"}], ",", 
    RowBox[{
     RowBox[{"n0", "=", "ne"}], ";", "\[IndentingNewLine]", 
     RowBox[{"n0", "=", 
      FractionBox["ne", 
       SuperscriptBox["10", "6"]]}], ";", " ", 
     RowBox[{"(*", " ", "MKS", " ", "*)"}], "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"mass", "[", "0", "]"}], "=", "1."}], ";", 
     RowBox[{
      RowBox[{"mass", "[", "1", "]"}], "=", "1836."}], ";", 
     RowBox[{
      RowBox[{"mass", "[", "2", "]"}], "=", "3670."}], ";", 
     RowBox[{
      RowBox[{"mass", "[", "3", "]"}], "=", "5497."}], ";", 
     RowBox[{
      RowBox[{"mass", "[", "4", "]"}], "=", "5496."}], ";", 
     RowBox[{
      RowBox[{"mass", "[", "5", "]"}], "=", "7294."}], ";", 
     RowBox[{
      RowBox[{"chg", "[", "0", "]"}], "=", 
      RowBox[{"-", "1."}]}], ";", 
     RowBox[{
      RowBox[{"chg", "[", "1", "]"}], "=", "1."}], ";", 
     RowBox[{
      RowBox[{"chg", "[", "2", "]"}], "=", "1."}], ";", 
     RowBox[{
      RowBox[{"chg", "[", "3", "]"}], "=", "1."}], ";", 
     RowBox[{
      RowBox[{"chg", "[", "4", "]"}], "=", "2."}], ";", 
     RowBox[{
      RowBox[{"chg", "[", "5", "]"}], "=", "2."}], ";", "\[IndentingNewLine]",
      "\[IndentingNewLine]", 
     RowBox[{"fp", " ", "=", " ", 
      RowBox[{"8.9787", "\[Times]", 
       SuperscriptBox["10.", "3"], " ", 
       SqrtBox[
        FractionBox[
         RowBox[{"n0", " ", "eta", " ", 
          SuperscriptBox[
           RowBox[{"chg", "[", "i", "]"}], "2"]}], 
         RowBox[{"mass", "[", "i", "]"}]]]}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{"print", "\[Equal]", "True"}], ",", 
       RowBox[{"Print", "[", 
        RowBox[{"\"\<\!\(\*SubscriptBox[\(f\), \(ps\)]\)=\>\"", ",", 
         RowBox[{"Chop", "[", "fp", "]"}]}], "]"}]}], "]"}], ";", 
     "\[IndentingNewLine]", "fp"}]}], "]"}]}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.900964179983202*^9, 3.900964282050516*^9}, {
