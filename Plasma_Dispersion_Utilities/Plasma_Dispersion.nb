Cell[TextData[{
 "Numerical implementation of the Cold Plasma Conductivity Tensor - 4\[Pi]i/\
\[Omega] \[Sigma] for a single species, SigmaCold[ ]. Returns list of length \
4 \[RightArrow]{",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Sigma]", "11"], TraditionalForm]],ExpressionUUID->
  "36c24fc7-1e1c-4d80-a6ff-056193da0752"],
 ", ",
 Cell[BoxData[
