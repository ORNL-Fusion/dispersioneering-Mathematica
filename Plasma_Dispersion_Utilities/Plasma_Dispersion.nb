Cell[BoxData[
 RowBox[{
  RowBox[{"ColdDis0", "[", 
   RowBox[{"freq_", ",", "ne_", ",", "B_", ",", "nz_", ",", "etaList_List"}], 
   "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "n0", ",", "B0", ",", "eta", ",", "mass", ",", "chg", ",", "fp", ",", 
      "fc", ",", "R", ",", "L", ",", "S"}], "}"}], ",", 
    RowBox[{
     RowBox[{"n0", "=", 
      FractionBox["ne", 
       SuperscriptBox["10", "6"]]}], ";", 
     RowBox[{"B0", "=", 
      RowBox[{"B", " ", 
       SuperscriptBox["10", "4"]}]}], ";", 
     RowBox[{
      RowBox[{"eta", "[", "0", "]"}], "=", "1."}], ";", 
     RowBox[{"Do", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"eta", "[", "i", "]"}], "=", 
        RowBox[{
        "etaList", "\[LeftDoubleBracket]", "i", "\[RightDoubleBracket]"}]}], 
       ",", 
       RowBox[{"{", 
        RowBox[{"i", ",", "1", ",", "5"}], "}"}]}], "]"}], ";", 
     RowBox[{
      RowBox[{"mass", "[", "0", "]"}], "=", "1."}], ";", 
