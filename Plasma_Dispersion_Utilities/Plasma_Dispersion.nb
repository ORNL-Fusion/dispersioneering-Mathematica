          RowBox[{"fp", "[", "i", "]"}], "2"], 
         RowBox[{"freq", " ", 
          RowBox[{"(", 
           RowBox[{"freq", "+", 
            RowBox[{"fc", "[", "i", "]"}]}], ")"}]}]]}]}]}], ";", 
     RowBox[{"L", "=", 
      RowBox[{"1", "-", 
       RowBox[{
        UnderoverscriptBox["\[Sum]", 
