Cell[CellGroupData[{

Cell[TextData[{
 "coeffBookerQ[X, Y, ny, nz ,\[Theta] ]  Coefficients of Booker quartic, \
electrons only. \n",
 Cell[BoxData[
  RowBox[{"X", "=", 
   SuperscriptBox[
    RowBox[{"(", 
     FractionBox[
      SubscriptBox["\[Omega]", "pe"], "\[Omega]"], ")"}], "2"]}]],
  CellChangeTimes->{{3.976463552657381*^9, 3.976463584831806*^9}},
  ExpressionUUID->"ae9a9562-8d73-42b4-a236-b142ee6356d7"],
 ", ",
 Cell[BoxData[
  RowBox[{"y", "=", 
   FractionBox[
    SubscriptBox["\[CapitalOmega]", "ce"], "\[Omega]"]}]],
  CellChangeTimes->{{3.976463552657381*^9, 3.976463643592845*^9}},
  ExpressionUUID->"d1e68979-bee0-4025-9195-fdfbaa2ef4f2"],
 ", B is in X-Z plane, \[Theta] = angle between B and Z-axis\n Returns list \
{c0,c1,c2,c3,c4} where the number refer to the power of nx in the dispersion \
relation"
}], "Section",
 CellChangeTimes->{{3.9753408235802193`*^9, 3.975340841636516*^9}, {
  3.976462997558998*^9, 3.976463064972642*^9}, {3.976463325521744*^9, 
  3.976463339109439*^9}, {3.976463370199394*^9, 3.9764634084896603`*^9}, {
  3.976463443531637*^9, 3.9764635474054747`*^9}, {3.976463593905095*^9, 
  3.97646359560253*^9}, {3.97646364976552*^9, 
  3.97646376205667*^9}},ExpressionUUID->"2454a1f5-5af2-46f0-a5a2-\
164bd5f7a648"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"coeffBookerQ", "[", 
    RowBox[{"X_", ",", "Y_", ",", "ny_", ",", "nz_", ",", "\[Theta]_"}], 
    "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"c0", ",", "c1", ",", "c2", ",", "c3", ",", "c4"}], "}"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"c4", "=", 
       RowBox[{
        RowBox[{
         RowBox[{"(", 
          RowBox[{"1", "-", 
           RowBox[{"X", "/", 
            RowBox[{"(", 
             RowBox[{"1", "-", 
              RowBox[{"Y", "^", "2"}]}], ")"}]}]}], ")"}], " ", 
         RowBox[{
          RowBox[{"Cos", "[", "\[Theta]", "]"}], "^", "2"}]}], "+", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"1", "-", "X"}], ")"}], " ", 
         RowBox[{
          RowBox[{"Sin", "[", "\[Theta]", "]"}], "^", "2"}]}]}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"c3", "=", 
       RowBox[{"-", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"2", " ", "nz", " ", "X", " ", 
            RowBox[{"Y", "^", "2"}], " ", 
            RowBox[{"Cos", "[", "\[Theta]", "]"}], " ", 
            RowBox[{"Sin", "[", "\[Theta]", "]"}]}], ")"}], "/", 
          RowBox[{"(", 
           RowBox[{
