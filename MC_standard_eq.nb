Notebook[{

Cell[CellGroupData[{
Cell[BoxData[{
 RowBox[{"Stix", " ", "\"\<Standard\>\"", " ", "mode", " ", "conversion", " ",
   "equation"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   FractionBox[
    RowBox[{
     SuperscriptBox["d", "4"], "E"}], 
    SuperscriptBox["dx", "4"]], "+", 
   RowBox[{
    SuperscriptBox["\[Lambda]", "2"], 
    RowBox[{"(", 
     RowBox[{"x", "-", 
      SubscriptBox["x", "0"]}], ")"}], 
    FractionBox[
     RowBox[{
      SuperscriptBox["d", "2"], "E"}], 
     SuperscriptBox["dx", "2"]]}], "+", "\[Gamma]E"}], "=", 
  "0"}]}], "Subsection",
 CellChangeTimes->{{3.798979275742293*^9, 
  3.7989794906746197`*^9}},ExpressionUUID->"953c1b77-83ff-4fd3-91dc-\
0b4d7158cac3"],

Cell[CellGroupData[{

Cell[TextData[{
 "Dispersion relation for ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["k", "2"], TraditionalForm]],ExpressionUUID->
  "0a47a228-147f-40c3-9702-1b753828f192"]
}], "Subsubsection",
 CellChangeTimes->{{3.79897950103671*^9, 3.798979507961019*^9}, {
  3.798979627257043*^9, 
  3.798979634315941*^9}},ExpressionUUID->"5cc36e8b-754a-41bb-baa3-\
bacca202846b"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"roots", "=", 
  RowBox[{"Solve", "[", 
   RowBox[{
    RowBox[{
     RowBox[{
      SuperscriptBox["k", 
       RowBox[{"2", " "}]], "+", 
      RowBox[{
       SuperscriptBox["\[Lambda]", "2"], " ", "x", " ", "k"}], "+", 
      "\[Gamma]"}], "\[Equal]", "0"}], ",", "k"}], "]"}]}]], "Input",
 CellChangeTimes->{{3.798935300507704*^9, 3.7989354400555153`*^9}, {
  3.798935540290207*^9, 3.798935543801693*^9}},
 CellLabel->"In[1]:=",ExpressionUUID->"1457aa43-55a7-43de-beb1-9df44ee0e754"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"k", "\[Rule]", 
     RowBox[{
      FractionBox["1", "2"], " ", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{
         RowBox[{"-", "x"}], " ", 
         SuperscriptBox["\[Lambda]", "2"]}], "-", 
        SqrtBox[
         RowBox[{
          RowBox[{
           RowBox[{"-", "4"}], " ", "\[Gamma]"}], "+", 
          RowBox[{
           SuperscriptBox["x", "2"], " ", 
           SuperscriptBox["\[Lambda]", "4"]}]}]]}], ")"}]}]}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"k", "\[Rule]", 
     RowBox[{
      FractionBox["1", "2"], " ", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{
         RowBox[{"-", "x"}], " ", 
         SuperscriptBox["\[Lambda]", "2"]}], "+", 
        SqrtBox[
         RowBox[{
          RowBox[{
           RowBox[{"-", "4"}], " ", "\[Gamma]"}], "+", 
          RowBox[{
           SuperscriptBox["x", "2"], " ", 
           SuperscriptBox["\[Lambda]", "4"]}]}]]}], ")"}]}]}], "}"}]}], 
  "}"}]], "Output",
 CellChangeTimes->{{3.798935425269815*^9, 3.798935441430455*^9}, 
   3.7989355466928053`*^9, 3.798936721720566*^9, 3.79893684628505*^9, 
   3.9499321389003353`*^9},
 CellLabel->"Out[1]=",ExpressionUUID->"af679046-9279-4b86-841c-ea81227d47b3"]
}, Open  ]],

Cell[BoxData[{
 RowBox[{
  RowBox[{"kp", "=", 
   RowBox[{"k", "/.", 
    RowBox[{"roots", "[", 
     RowBox[{"[", "1", "]"}], "]"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"km", "=", 
   RowBox[{"k", "/.", 
    RowBox[{"roots", "[", 
     RowBox[{"[", "2", "]"}], "]"}]}]}], ";"}]}], "Input",
 CellChangeTimes->{{3.798935552836246*^9, 3.798935595213842*^9}, {
  3.798936685727359*^9, 3.79893668853995*^9}},
 CellLabel->"In[2]:=",ExpressionUUID->"3882ed39-5acd-4e79-9233-53cf401e52d2"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"rp", "[", 
    RowBox[{"x_", ",", "\[Lambda]_", ",", "\[Gamma]_"}], "]"}], "=", "kp"}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"rm", "[", 
    RowBox[{"x_", ",", "\[Lambda]_", ",", "\[Gamma]_"}], "]"}], "=", "km"}], 
  ";"}]}], "Input",
 CellChangeTimes->{{3.7989356142916193`*^9, 3.798935736041646*^9}},
 CellLabel->"In[4]:=",ExpressionUUID->"fd837d3e-9812-4fb6-9b47-9a1ffb853d52"]
}, Open  ]]
}, Open  ]],

