Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"nxhot", "[", "iRoot_", "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
       "iRoot0", ",", "nxWarm", ",", "rootsWarm", ",", "nxH", ",", "x0", ",", 
        "ne", ",", "b", ",", "t", ",", "TL"}], "}"}], ",", 
      "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"nxWarm", "=", 
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{"Flatten", "[", 
           RowBox[{"{", 
            RowBox[{"x", ",", 
             RowBox[{"nPerpWarm6", "[", "x", "]"}]}], "}"}], "]"}], ",", 
          RowBox[{"{", 
           RowBox[{"x", ",", "xmin", ",", "xmax", ",", 
            FractionBox[
             RowBox[{"xmax", "-", "xmin"}], 
             RowBox[{"nPoints", "-", "1"}]]}], "}"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"iRoot0", "=", "iRoot"}], ";", "\[IndentingNewLine]", 
       RowBox[{"rootsWarm", "=", 
        RowBox[{"rootSort", "[", "nxWarm", "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"nxH", "=", 
        RowBox[{"Table", "[", 
         RowBox[{"0.", ",", 
          RowBox[{"{", 
           RowBox[{"i", ",", "1", ",", "nPoints"}], "}"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"Do", "[", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{"x0", "=", 
            RowBox[{"xmin", "+", 
             RowBox[{
              RowBox[{"(", 
               RowBox[{"i", "-", "1"}], ")"}], 
              FractionBox[
               RowBox[{"xmax", "-", "xmin"}], 
               RowBox[{"nPoints", "-", "1"}]]}]}]}], ";", 
           "\[IndentingNewLine]", 
           RowBox[{"nxGuess", "=", 
            RowBox[{
             RowBox[{"rootsWarm", "[", 
              RowBox[{"[", "i", "]"}], "]"}], "[", 
             RowBox[{"[", 
              RowBox[{"iRoot0", "+", "1"}], "]"}], "]"}]}], ";", 
           "\[IndentingNewLine]", 
           RowBox[{"(*", 
            RowBox[{
             RowBox[{"Print", "[", 
              
              RowBox[{"\"\<x0 = \>\"", ",", " ", "x0", 
               ",", "\"\<  nxGuess= \>\"", ",", "nxGuess"}], "]"}], ";"}], 
