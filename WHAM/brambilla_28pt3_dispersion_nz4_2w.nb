               RowBox[{"x0", ",", "nxGuess"}], "]"}]}], "}"}]}], ";"}], ")"}],
          ",", 
         RowBox[{"{", 
          RowBox[{"i", ",", "1", ",", "nPoints"}], "}"}]}], "]"}], ";", 
       "\[IndentingNewLine]", "nxH"}]}], "]"}]}], ";"}], 
  "\[IndentingNewLine]", "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
