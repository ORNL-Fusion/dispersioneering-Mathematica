          RowBox[{"x", ",", "xmin", ",", "xmax", ",", 
           FractionBox[
            RowBox[{"xmax", "-", "xmin"}], 
            RowBox[{"nPoints", "-", "1"}]]}], "}"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"iRoot0", "=", "iRoot"}], ";", "\[IndentingNewLine]", 
      RowBox[{"rootsWarm", "=", 
       RowBox[{"rootSort", "[", "nxWarm", "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"nxH", "=", 
       RowBox[{"Table", "[", 
        RowBox[{"0.", ",", 
         RowBox[{"{", 
