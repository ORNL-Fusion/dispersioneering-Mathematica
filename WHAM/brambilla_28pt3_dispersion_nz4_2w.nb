Cell["Now Try with Hot Plasma Dispersion using root finder", "Section",
 CellChangeTimes->{{3.7856310546593847`*^9, 3.78563110052183*^9}, {
  3.785755944014817*^9, 
  3.785755948051633*^9}},ExpressionUUID->"82b513d6-585b-4d59-bc44-\
5afe3bd214d6"],

Cell[BoxData[
 RowBox[{
  RowBox[{"nPerpHot", "[", 
   RowBox[{"x_", ",", "nxGuess_"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"ne", ",", "b", ",", "x0", ",", "TL", ",", "nx0", ",", "rootRule"}], "}"}], ",", 
    "\n", "\t\t", 
    RowBox[{
     RowBox[{"x0", "=", "x"}], ";", "\[IndentingNewLine]", 
     RowBox[{"nx0", "=", "nxGuess"}], ";", "\n", "     ", 
     RowBox[{"ne", "=", 
      RowBox[{"nprof", "[", "x0", "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"b", "=", 
      RowBox[{"bprof", "[", "x0", "]"}]}], ";", "\n", "     ", 
     RowBox[{"TL", "=", 
      RowBox[{
       RowBox[{"tprof", "[", "x0", "]"}], "*", "TList"}]}], ";", "\n", 
     RowBox[{"rootRule", "=", 
      RowBox[{"Quiet", "[", 
       RowBox[{
        RowBox[{"Check", "[", 
         RowBox[{
          RowBox[{"FindRoot", "[", 
           RowBox[{
            RowBox[{"DisFuncGeneral", "[", 
             RowBox[{
             "freq", ",", "ne", ",", "b", ",", "nz", ",", "nx", ",", "etaList", ",",
               "TL", ",", "nminList", ",", "nmaxList", ",", "modelList"}], "]"}], 
            ",", 
            RowBox[{"{", 
             RowBox[{"nx", ",", "nx0"}], "}"}], ",", " ", 
            RowBox[{"MaxIterations", "\[Rule]", "100"}]}], "]"}], ",", 
          RowBox[{"{", 
           RowBox[{"nx", "\[Rule]", "Indeterminate"}], "}"}]}], "]"}], ",", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"General", "::", "munfl"}], ",", 
          RowBox[{"FindRoot", "::", "lstol"}], ",", 
          RowBox[{"FindRoot", "::", "cvmit"}]}], "}"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"nx", "/.", "rootRule"}]}]}], "]"}]}]], "Input",
 CellChangeTimes->{{3.785686978436041*^9, 3.785687015566174*^9}, {
   3.7856872102869997`*^9, 3.7856872471230907`*^9}, 3.785687963878316*^9, {
