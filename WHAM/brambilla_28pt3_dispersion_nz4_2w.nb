Cell["Magnetic field,Density and Temperature Profiles", "Subsubsection",
 Evaluatable->False,
 AspectRatioFixed->
  True,ExpressionUUID->"5de37e7b-5cb9-4f21-98b5-565fbe356d79"],

Cell[BoxData["ClearAll[nprof, bprof, tprof, nprof2, bprof2, tprof2, whamLinearProfile];\nwhamLinearProfile[x_, xminValue_, xmaxValue_] := If[Abs[(xmaxValue - xminValue)/xmaxValue] > 10^-6, xminValue + ((x - xProfileMin)/(xProfileMax - xProfileMin))*(xmaxValue - xminValue), xminValue];\nbprof2[x_?NumericQ] := 14.71*x^6 + 0.0003099*x^5 + 4.654*x^4 - 0.000302*x^3 - 0.9664*x^2 + 2.809*10^-5*x + 0.845;\nnprof2[x_?NumericQ] := whamLinearProfile[x, nXmin, nXmax];\ntprof2[x_?NumericQ] := whamLinearProfile[x, TXmin, TXmax];\nbprof[x_?NumericQ] := bprof2[x];\nnprof[x_?NumericQ] := nprof2[x];\ntprof[x_?NumericQ] := tprof2[x];\nwci = q*bprof[x]/mi;\nwce = q*bprof[x]/me;\nwpe = Sqrt[nprof[x]*q^2/(ep0*me)];\ndh = Plot[5/Mod[Abs[1 - w/wci], 1], {x, xProfileMin, xProfileMax}, PlotRange -> {0.01, 2*10^3}, PlotStyle -> Green];\nprofileSummary = Grid[Prepend[Table[{r, nprof[r], tprof[r], bprof[r]}, {r, {xProfileMin, xProfileMax}}], {\"x (m)\", \"ne (m^-3)\", \"Te (keV)\", \"B (T)\"}], Frame -> All];\nprofilePlots = GraphicsRow[{Plot[nprof[x], {x, xProfileMin, xProfileMax}, PlotRange -> All, PlotLabel -> \"ne\"], Plot[tprof[x], {x, xProfileMin, xProfileMax}, PlotRange -> All, PlotLabel -> \"Te (keV)\"], Plot[bprof[x], {x, xProfileMin, xProfileMax}, PlotRange -> All, PlotLabel -> \"B (T)\"]}, ImageSize -> Large];\nColumn[{profileSummary, profilePlots, dh}]"], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.9902*^9, 3.9902*^9}},
 ExpressionUUID->"f5d2b283-7543-45b6-ae59-1db9dff30dfd"]
},
